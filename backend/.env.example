# ===== Required =====

# Long random string. Used to sign session JWTs. Rotate to invalidate all sessions.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ===== ElevenLabs (voice cloning + TTS) =====
# Get a key at https://elevenlabs.io. Free tier is enough to start.
ELEVENLABS_API_KEY=

# ===== Stripe billing (optional — enables /pricing checkout) =====
# Test keys start with sk_test_ / pk_test_.
# Use the Stripe CLI for local webhooks:
#   stripe listen --forward-to localhost:3001/api/billing/webhook
# That command prints the STRIPE_WEBHOOK_SECRET to paste below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# ===== App config =====
PORT=3001
NODE_ENV=development

# Public URL of the frontend (used for Stripe redirect URLs and CORS)
APP_URL=http://localhost:5173

# When true, sets Secure flag on session cookies (required for HTTPS prod).
# Defaults to true in production. Leave blank in local dev.
COOKIE_SECURE=

# SQLite database path (relative to backend cwd)
DATABASE_PATH=./data/cappisco.db

# ===== Quotas (server-enforced limits) =====
FREE_DAILY_TRANSLATIONS=5
BASIC_MONTHLY_SYNTH_CHARS=50000
PRO_MONTHLY_SYNTH_CHARS=250000

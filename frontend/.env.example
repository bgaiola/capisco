# =====================================================================
#  Frontend env vars — exposed to the browser.
#  Anything prefixed with VITE_ becomes available via import.meta.env.
#  Never put secrets in here.
# =====================================================================

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXX). Optional.
# When set, the app loads gtag.js and emits page_view + sign_up + begin_checkout events.
VITE_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID. Optional.
# When set, the app loads fbq and emits PageView + CompleteRegistration + InitiateCheckout.
VITE_META_PIXEL_ID=
